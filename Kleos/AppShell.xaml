<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Kleos.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Kleos.Views"
    Shell.NavBarIsVisible="False">

    <!--  Auth routes (no tab bar)  -->
    <ShellContent
        x:Name="LoginShell"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage"
        Shell.TabBarIsVisible="False" />

    <ShellContent
        ContentTemplate="{DataTemplate views:RegisterPage}"
        Route="RegisterPage"
        Shell.TabBarIsVisible="False" />

    <!--  Main tab bar  -->
    <TabBar x:Name="MainTabBar">

        <Tab Title="Tasks" Icon="icon_home.png">
            <ShellContent ContentTemplate="{DataTemplate views:TodoPage}" Route="TodoPage" />
        </Tab>

        <Tab Title="Done" Icon="icon_check_circle.png">
            <ShellContent ContentTemplate="{DataTemplate views:CompletedPage}" Route="CompletedPage" />
        </Tab>

        <Tab Title="Streaks" Icon="icon_flame.png">
            <ShellContent ContentTemplate="{DataTemplate views:StreaksPage}" Route="StreaksPage" />
        </Tab>

        <Tab Title="Insights" Icon="icon_chart.png">
            <ShellContent ContentTemplate="{DataTemplate views:InsightsPage}" Route="InsightsPage" />
        </Tab>

        <Tab Title="Profile" Icon="icon_user.png">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" Route="ProfilePage" />
        </Tab>

    </TabBar>

    <!--  Modal / Push routes  -->
    <Shell.Routes>
        <!--  These are registered in AppShell.xaml.cs  -->
    </Shell.Routes>

</Shell>