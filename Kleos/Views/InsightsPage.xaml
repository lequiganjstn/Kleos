<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Kleos.Views.InsightsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource PrimaryColor}"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24,52,24,32" Spacing="16">

            <Label Style="{StaticResource HeadingLabel}" Text="Insights" />
            <Label
                Margin="0,-8,0,0"
                Style="{StaticResource SubheadingLabel}"
                Text="Your productivity at a glance." />

            <!--  Completion Rate  -->
            <Frame
                Margin="0,8,0,0"
                Padding="24"
                BackgroundColor="{StaticResource SurfaceColor}"
                Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource SectionHeader}" Text="COMPLETION RATE" />
                    <Label
                        FontFamily="RobotoBold"
                        FontSize="48"
                        Text="{Binding CompletionRate, StringFormat='{0}%'}"
                        TextColor="{StaticResource AccentColor}" />
                    <ProgressBar
                        BackgroundColor="{StaticResource BorderColor}"
                        Progress="{Binding CompletionRate, Converter={StaticResource PercentToDecimalConverter}}"
                        ProgressColor="{StaticResource AccentColor}" />
                    <Label Style="{StaticResource CaptionLabel}" Text="{Binding TotalTasks, StringFormat='of {0} total tasks'}" />
                </VerticalStackLayout>
            </Frame>

            <!--  Stats Grid  -->
            <Grid
                ColumnDefinitions="*,*"
                ColumnSpacing="12"
                RowDefinitions="Auto,Auto"
                RowSpacing="12">

                <Frame
                    Grid.Row="0"
                    Grid.Column="0"
                    Padding="20"
                    Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontFamily="RobotoBold"
                            FontSize="32"
                            Text="{Binding CompletedTasks}"
                            TextColor="{StaticResource SuccessColor}" />
                        <Label Style="{StaticResource CaptionLabel}" Text="Tasks Completed" />
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Row="0"
                    Grid.Column="1"
                    Padding="20"
                    Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontFamily="RobotoBold"
                            FontSize="32"
                            Text="{Binding PendingTasks}"
                            TextColor="{StaticResource WarningColor}" />
                        <Label Style="{StaticResource CaptionLabel}" Text="Pending Tasks" />
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Row="1"
                    Grid.Column="0"
                    Padding="20"
                    Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontFamily="RobotoBold"
                            FontSize="32"
                            Text="{Binding CompletedThisWeek}"
                            TextColor="{StaticResource AccentSecondary}" />
                        <Label Style="{StaticResource CaptionLabel}" Text="Done This Week" />
                    </VerticalStackLayout>
                </Frame>

                <Frame
                    Grid.Row="1"
                    Grid.Column="1"
                    Padding="20"
                    Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontFamily="RobotoBold"
                            FontSize="32"
                            Text="{Binding TotalFocusMinutes}"
                            TextColor="{StaticResource AccentColor}" />
                        <Label Style="{StaticResource CaptionLabel}" Text="Focus Minutes" />
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!--  Details  -->
            <Frame Padding="20" Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            Style="{StaticResource BodyLabel}"
                            Text="High priority completed" />
                        <Label
                            Grid.Column="1"
                            FontFamily="RobotoMedium"
                            FontSize="15"
                            Text="{Binding HighPriorityCompleted}"
                            TextColor="{StaticResource PriorityHigh}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            Style="{StaticResource BodyLabel}"
                            Text="Top category" />
                        <Label
                            Grid.Column="1"
                            FontFamily="RobotoMedium"
                            FontSize="15"
                            Text="{Binding TopCategory}"
                            TextColor="{StaticResource AccentColor}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>