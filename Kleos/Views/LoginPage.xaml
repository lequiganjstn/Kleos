<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Kleos.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Kleos.ViewModels"
    BackgroundColor="{StaticResource PrimaryColor}"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!--  Logo Area  -->
            <Label
                Margin="0,0,0,8"
                CharacterSpacing="8"
                FontFamily="RobotoBold"
                FontSize="40"
                HorizontalOptions="Center"
                Text="KLEOS"
                TextColor="{StaticResource AccentColor}" />

            <Label
                Margin="0,0,0,56"
                HorizontalOptions="Center"
                Style="{StaticResource SubheadingLabel}"
                Text="Own your day." />

            <!--  Email Field  -->
            <Frame
                Margin="0,0,0,12"
                Padding="16,12"
                Style="{StaticResource CardFrame}">
                <Grid ColumnDefinitions="24,*" ColumnSpacing="12">
                    <Image
                        Grid.Column="0"
                        HeightRequest="20"
                        Source="icon_mail.png"
                        VerticalOptions="Center"
                        WidthRequest="20" />
                    <Entry
                        Grid.Column="1"
                        Keyboard="Email"
                        Placeholder="Email address"
                        Style="{StaticResource InputEntry}"
                        Text="{Binding Email}" />
                </Grid>
            </Frame>

            <!--  Password Field  -->
            <Frame
                Margin="0,0,0,8"
                Padding="16,12"
                Style="{StaticResource CardFrame}">
                <Grid ColumnDefinitions="24,*,32" ColumnSpacing="12">
                    <Image
                        Grid.Column="0"
                        HeightRequest="20"
                        Source="icon_lock.png"
                        VerticalOptions="Center"
                        WidthRequest="20" />
                    <Entry
                        Grid.Column="1"
                        IsPassword="{Binding ShowPassword, Converter={StaticResource InverseBoolConverter}}"
                        Placeholder="Password"
                        Style="{StaticResource InputEntry}"
                        Text="{Binding Password}" />
                    <ImageButton
                        Grid.Column="2"
                        BackgroundColor="Transparent"
                        Command="{Binding ToggleShowPasswordCommand}"
                        HeightRequest="20"
                        Source="icon_eye.png"
                        VerticalOptions="Center"
                        WidthRequest="20" />
                </Grid>
            </Frame>

            <!--  Error Message  -->
            <Label
                Margin="0,0,0,16"
                FontFamily="RobotoRegular"
                FontSize="13"
                IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                Text="{Binding ErrorMessage}"
                TextColor="{StaticResource DangerColor}" />

            <!--  Login Button  -->
            <Button
                Margin="0,20,0,0"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding IsNotBusy}"
                Style="{StaticResource PrimaryButton}"
                Text="Sign In" />

            <!--  Loading Indicator  -->
            <ActivityIndicator
                Margin="0,12,0,0"
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource AccentColor}" />

            <!--  Register Link  -->
            <HorizontalStackLayout
                Margin="0,32,0,0"
                HorizontalOptions="Center"
                Spacing="4">
                <Label Style="{StaticResource SubheadingLabel}" Text="Don't have an account?" />
                <Label
                    FontFamily="RobotoMedium"
                    FontSize="14"
                    Text="Sign Up"
                    TextColor="{StaticResource AccentColor}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>